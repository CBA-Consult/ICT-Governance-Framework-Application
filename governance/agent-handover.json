{
  "rpas_version": "RPAS-CM-2.3.0",
  "purpose": "Operational handover for agents working in the ICT Governance Framework with in-repo ADPA.",
  "product": {
    "name": "ICT Governance Framework with ADPA",
    "integrationMode": "in-repo",
    "adpaModule": "adpa/",
    "governanceModule": "governance/rpas/",
    "webApp": "ict-governance-framework/"
  },
  "lifecycle": "Proposal → Decision → Execution",
  "tier_architecture": {
    "intelligence": {
      "location": "adpa/scripts",
      "authority": "advisory-only",
      "restrictions": ["No state mutation", "Structured JSON output only"]
    },
    "orchestration": {
      "location": "governance/rpas/scripts",
      "authority": "execution",
      "responsibilities": ["AEV validation", "CSR baseline", "AMD rituals"]
    },
    "experience": {
      "location": "ict-governance-framework",
      "authority": "read-and-decide",
      "restrictions": ["No direct baseline mutation outside RPAS rituals"]
    },
    "data": {
      "location": "adpa/entities",
      "authority": "append-only",
      "schema": "adpa/schemas/telemetry-entity.schema.json"
    }
  },
  "rpas_guardrails": {
    "G1": "AI proposes; humans decide; orchestration executes.",
    "G2": "All state changes follow the ritual lifecycle in adpa/systematics/lifecycle.json.",
    "G3": "Artifacts require TAR-COL metadata per governance/schemas/rpas-tar-col.schema.json.",
    "G4": "Execution is idempotent and replay-safe.",
    "G5": "Experience tier cannot mutate governance state outside rituals."
  },
  "commands": {
    "adpa_validate": "npm run adpa:validate",
    "adpa_generate": "npm run adpa:generate",
    "adpa_prioritize": "npm run adpa:prioritize",
    "governance_validate": "npm run governance:validate",
    "governance_register": "npm run governance:register"
  },
  "documentation": [
    "adpa/README.md",
    "docs/implementation/guides/ADPA-ICT-Governance-Integration-Guide.md",
    "governance/CONTRIBUTING.md"
  ]
}
