# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ict_governance_framework

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# API Configuration
PORT=4000
NODE_ENV=development

# Frontend Configuration (use /api in dev — proxied to Express on :4000 via next.config.js)
NEXT_PUBLIC_API_URL=/api

# Microsoft Graph / Secure Score (optional — demo data is used locally when unset)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-app-client-id
# AZURE_CLIENT_SECRET=your-app-client-secret
# GRAPH_API_BASE_URL=https://graph.microsoft.com
# SECURE_SCORE_ALLOW_DEMO=true

# Gate A: Sentinel / SIEM webhook secret for POST /api/governance/incidents (optional)
# GOVERNANCE_WEBHOOK_SECRET=your-webhook-secret
# GOVERNANCE_API_URL=http://localhost:4000

# Gate B G-B1: Asset discovery sync webhook (falls back to GOVERNANCE_WEBHOOK_SECRET)
# ASSET_SYNC_WEBHOOK_SECRET=your-asset-sync-secret
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# Focus Area 5: CASB shadow IT ingest webhook for POST /api/assets/casb-ingest
# CASB_INGEST_WEBHOOK_SECRET=your-casb-ingest-secret
# CASB_MIN_RISK_SCORE=70

# Action 5.1: Microsoft Defender for Cloud Apps live polling
# DEFENDER_CASB_API_URL=https://your-tenant.portal.cloudappsecurity.com
# DEFENDER_CASB_API_TOKEN=your-defender-api-token
# DEFENDER_CASB_DISCOVERY_PATH=/api/v1/discovery/discovered_apps/
# CASB_POLLING_INTERVAL_MS=300000
# CASB_POLLING_BATCH_LIMIT=50
# DEFAULT_TENANT_ID=tenant-01
# ENABLE_BACKGROUND_WORKERS=true
# CASB_POLLING_DEMO=true

# JIT elevation (privileged mutation enforcement)
# JIT_ENFORCEMENT_ENABLED=false
# JIT_ELEVATION_SECRET=your-jit-signing-secret
# JIT_ELEVATION_TTL_MINUTES=60

# Break Glass emergency activation (out-of-band when identity infrastructure is degraded)
# BREAK_GLASS_ALLOWED=false
# BREAK_GLASS_SYSTEM_SECRET=your-cryptographic-emergency-break-glass-string
# BREAK_GLASS_MAX_DURATION_MINUTES=60
# BREAK_GLASS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/soc-emergency-channel

# FAIR live risk engine (FR-GOV-005 / GV.RM)
# ENABLE_FAIR_RISK_SWEEP=false
# FAIR_RISK_SWEEP_INTERVAL_MS=3600000
# FAIR_SHADOW_LEF_BOOST_PER_ASSET=0.15
# FAIR_DR_AT_RISK_LEF_BOOST=0.25
# FAIR_CRITICAL_INCIDENT_LEF_BOOST=0.10
# FAIR_BREAK_GLASS_LEF_BOOST=0.50
# FAIR_MAX_MULTIPLIER=5.0

# SecOps SLA targets (milliseconds) — audit-facing definitions
# SLA_CRITICAL_DETECT_TO_TICKET_MS=300000
# SLA_CRITICAL_TICKET_TO_ACK_MS=300000
# SLA_CRITICAL_MTTR_MS=3600000

# Legacy aliases (supported)

# Email Configuration (for future implementation)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=15m
REFRESH_TOKEN_TIMEOUT=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Production login attempts per 15 min per IP
AUTH_RATE_LIMIT_MAX=5
# Development login cap (localhost exempt when NODE_ENV=development)
AUTH_RATE_LIMIT_MAX_DEV=500
# Set AUTH_RATE_LIMIT_STRICT=true to enforce AUTH_RATE_LIMIT_MAX in development
REGISTER_RATE_LIMIT_MAX=3

# FAIR model calibration (Phase 4 — observed frequency tuning)
# FAIR_CALIBRATION_LEARNING_RATE=0.15
# FAIR_CALIBRATION_MIN_FACTOR=0.75
# FAIR_CALIBRATION_MAX_FACTOR=1.35
# FAIR_CALIBRATION_MAX_DELTA=0.10
# FAIR_CALIBRATION_AUTO_APPROVE_PCT=5
# FAIR_CALIBRATION_APPROVAL_THRESHOLD_PCT=10