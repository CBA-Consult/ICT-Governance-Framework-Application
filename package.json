{
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@modelcontextprotocol/server-memory": "^2025.11.25",
    "adpa-enterprise-framework-automation": "^3.2.0",
    "axios": "^1.17.0",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.2.1"
  },
  "scripts": {
    "start": "node server-multi-tenant.js",
    "start:dev": "NODE_ENV=development node server-multi-tenant.js",
    "governance:register": "node ./governance/rpas/scripts/run-powershell.js ./governance/rpas/scripts/register-governance.ps1",
    "governance:validate": "node ./governance/rpas/scripts/run-powershell.js ./governance/rpas/scripts/validate-aev.ps1",
    "governance:checksum": "node ./governance/rpas/scripts/run-powershell.js ./governance/rpas/scripts/validate-aev.ps1 -RefreshChecksum",
    "verify:gb3": "node ./governance/rpas/scripts/run-powershell.js ./governance/rpas/scripts/Test-GitToCloudRecovery.ps1",
    "adpa:validate": "node ./adpa/scripts/validate-project.js",
    "adpa:list": "node ./adpa/scripts/generate.js list",
    "adpa:generate": "node ./adpa/scripts/generate.js generate",
    "adpa:prioritize": "node ./adpa/scripts/prioritize-from-telemetry.js",
    "adpa:validate:templates": "node ./adpa/scripts/validate-templates.js",
    "adpa:list:artifacts": "node ./adpa/scripts/list-artifacts.js",
    "adpa:generate:governance-doc": "node ./adpa/scripts/generate-governance-doc.js",
    "adpa:setup:global-hubs": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1",
    "adpa:setup:global-hubs:firewall": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -FirewallOnly -AcknowledgeFirewallCost",
    "adpa:setup:global-hubs:vpn-gateway": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -VpnGatewayOnly -AcknowledgeVpnGatewayCost",
    "adpa:setup:global-hubs:expressroute-gateway": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -ExpressRouteGatewayOnly -AcknowledgeExpressRouteGatewayCost",
    "adpa:setup:global-hubs:bastion": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -BastionOnly -AcknowledgeBastionCost",
    "adpa:setup:global-hubs:peering": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -GlobalPeeringOnly -AcknowledgeGlobalPeeringCost",
    "adpa:setup:global-hubs:spoke-peering": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -SpokePeeringOnly -AcknowledgeSpokePeeringCost",
    "adpa:setup:global-hubs:spoke-routing": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -SpokeRoutingOnly -AcknowledgeSpokeRoutingCost",
    "adpa:setup:global-hubs:private-dns": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -PrivateDnsOnly -AcknowledgePrivateDnsCost",
    "adpa:setup:global-hubs:private-link": "node ./governance/rpas/scripts/run-powershell.js ./scripts/setup-global-network-hubs.ps1 -PrivateLinkOnly -AcknowledgePrivateLinkCost",
    "test": "playwright test",
    "test:user-management": "playwright test tests/user-management.spec.ts",
    "test:user-management:headed": "playwright test tests/user-management.spec.ts --headed",
    "test:user-management:debug": "playwright test tests/user-management.spec.ts --debug",
    "test:multi-tenant": "playwright test tests/multi-tenant-management.spec.ts",
    "test:multi-tenant:headed": "playwright test tests/multi-tenant-management.spec.ts --headed",
    "test:orchestrator": "jest tests/multi-cloud-orchestrator.test.js",
    "test:validate-env": "node tests/validate-test-environment.js",
    "test:report": "playwright show-report"
  }
