{
  "templateId": "data-protection",
  "version": "1.0.0",
  "artifactType": "hybrid",
  "pillar": "data",
  "displayName": "Data Classification & Protection",
  "description": "Converts data governance requirements (classification, encryption, DLP, retention) into IaC and compliance policy specifications.",
  "frameworkRefs": [
    "blueprint-templates/compliance-blueprints/gdpr-compliance.bicep",
    "blueprint-templates/policy-templates/data-privacy-policy.md"
  ],
  "nistCategories": ["PR.DS", "GV.PO"],
  "governanceRequirement": {
    "schemaRef": "adpa/schemas/governance-requirement.schema.json",
    "requiredFields": [
      "requirementId",
      "title",
      "statement",
      "parameters.classificationLevels",
      "parameters.encryptionAtRest",
      "parameters.encryptionInTransit"
    ],
    "optionalFields": [
      "parameters.dlpEnabled",
      "parameters.retentionDays",
      "parameters.geoRestriction"
    ]
  },
  "llmProcessing": {
    "systemInstructionsRef": "adpa/templates/governance-artifacts/llm-prompts/system-instructions.json",
    "userPromptTemplate": "Convert the following data protection governance requirement into a hybrid-specification.\n\nRequirement ID: {{requirementId}}\nTitle: {{title}}\nStatement: {{statement}}\nParameters: {{parameters}}\nFramework mappings: {{frameworkMappings}}\n\nProduce JSON with controls for classification labels, encryption, DLP rules, and retention policies.",
    "outputFormat": "json",
    "temperature": 0.2,
    "validationRules": [
      "Encryption at rest and in transit must both appear when required",
      "Classification levels must map to tag or label enforcement controls"
    ]
  },
  "outputSchema": {
    "schemaRef": "adpa/schemas/generated-artifact.schema.json",
    "artifactKind": "hybrid-specification"
  },
  "iacTargets": {
    "azure": {
      "format": "bicep",
      "translatorModule": "adpa/translators/azure/data-protection.bicep.js",
      "referenceBlueprint": "blueprint-templates/compliance-blueprints/gdpr-compliance.bicep",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/azure/data-{{requirementId}}.bicep"
    },
    "aws": {
      "format": "terraform",
      "translatorModule": "adpa/translators/aws/data-protection.tf.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/aws/data-{{requirementId}}.tf"
    },
    "gcp": {
      "format": "terraform",
      "translatorModule": "adpa/translators/gcp/data-protection.tf.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/gcp/data-{{requirementId}}.tf"
    }
  },
  "complianceTargets": {
    "azurePolicy": {
      "format": "azure-policy",
      "translatorModule": "adpa/translators/azure/data-protection.policy.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/azure/policies/data-{{requirementId}}.json"
    },
    "awsConfig": {
      "format": "aws-config-rule",
      "translatorModule": "adpa/translators/aws/data-protection.config.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/aws/config/data-{{requirementId}}.json"
    },
    "gcpOrgPolicy": {
      "format": "gcp-org-policy",
      "translatorModule": "adpa/translators/gcp/data-protection.orgpolicy.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/gcp/policies/data-{{requirementId}}.yaml"
    }
  },
  "rpasBinding": {
    "csrBaseline": "CSR-42",
    "driftClass": "security",
    "tarColArtifactId": "TAR-ARM-002"
  }
}
