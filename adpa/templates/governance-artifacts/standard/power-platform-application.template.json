{
  "templateId": "power-platform-application",
  "version": "1.0.0",
  "artifactType": "hybrid",
  "pillar": "software",
  "displayName": "Power Platform Application Asset",
  "description": "Each Power App or Power Automate flow is registered as a separate software artifact asset with DLP, environment, and compliance governance.",
  "frameworkRefs": [
    "docs/governance-framework/core-framework/Multi-Cloud-Multi-Tenant-ICT-Governance-Framework.md",
    "blueprint-templates/policy-templates/technology-selection-policy.md"
  ],
  "nistCategories": ["GV.SC", "ID.AM", "PR.PS"],
  "governanceRequirement": {
    "schemaRef": "adpa/schemas/governance-requirement.schema.json",
    "requiredFields": [
      "requirementId",
      "title",
      "statement",
      "parameters.applicationType",
      "parameters.environmentId",
      "parameters.dataClassification"
    ],
    "optionalFields": [
      "parameters.connectorInventory",
      "parameters.dlpPolicyRef",
      "parameters.managedEnvironment",
      "parameters.ownerUpn"
    ],
    "examplePath": "adpa/tenants/tenant-contoso-health/requirements/power-app-expense-tracker-requirement.json"
  },
  "llmProcessing": {
    "systemInstructionsRef": "adpa/templates/governance-artifacts/llm-prompts/system-instructions.json",
    "userPromptTemplate": "Convert the following Power Platform application governance requirement into a hybrid-specification. Each app is a distinct software artifact under multi-cloud ICT governance.\n\nRequirement ID: {{requirementId}}\nTitle: {{title}}\nStatement: {{statement}}\nParameters: {{parameters}}\n\nProduce JSON with controls for DLP compliance, connector restrictions, environment isolation, and audit logging.",
    "outputFormat": "json",
    "temperature": 0.2,
    "validationRules": [
      "Application must map to assetClass software-power-platform-app or software-power-platform-flow",
      "Environment must be non-Default for production workloads",
      "Data classification must drive connector and sharing restrictions"
    ]
  },
  "outputSchema": {
    "schemaRef": "adpa/schemas/generated-artifact.schema.json",
    "artifactKind": "hybrid-specification"
  },
  "iacTargets": {
    "azure": {
      "format": "bicep",
      "translatorModule": "adpa/translators/azure/power-platform-application.bicep.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/azure/powerapp-{{requirementId}}.bicep"
    }
  },
  "complianceTargets": {
    "azurePolicy": {
      "format": "dlp-policy",
      "translatorModule": "adpa/translators/power-platform/dlp-policy.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/power-platform/dlp-{{requirementId}}.json"
    }
  },
  "rpasBinding": {
    "csrBaseline": "CSR-42",
    "driftClass": "governance",
    "tarColArtifactId": "TAR-ARM-002"
  }
}
