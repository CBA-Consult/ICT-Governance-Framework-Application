{
  "templateId": "device-compliance",
  "version": "1.0.0",
  "artifactType": "hybrid",
  "pillar": "devices",
  "displayName": "Device Compliance & Endpoint Governance",
  "description": "Converts device governance requirements (MDM enrollment, compliance baselines, patch levels) into endpoint management IaC and policy specs.",
  "frameworkRefs": [
    "docs/implementation/guides/Enterprise-Security-Seven-Pillar-Implementation-Plan.md"
  ],
  "nistCategories": ["ID.AM", "PR.PS"],
  "governanceRequirement": {
    "schemaRef": "adpa/schemas/governance-requirement.schema.json",
    "requiredFields": [
      "requirementId",
      "title",
      "statement",
      "scope.cloudProviders",
      "parameters.mdmRequired",
      "parameters.minimumOsVersion"
    ],
    "optionalFields": [
      "parameters.encryptionRequired",
      "parameters.jailbreakDetection",
      "parameters.allowedDevicePlatforms"
    ]
  },
  "llmProcessing": {
    "systemInstructionsRef": "adpa/templates/governance-artifacts/llm-prompts/system-instructions.json",
    "userPromptTemplate": "Convert the following device governance requirement into a hybrid specification for endpoint compliance.\n\nRequirement ID: {{requirementId}}\nTitle: {{title}}\nStatement: {{statement}}\nAcceptance criteria: {{acceptanceCriteria}}\nScope: {{scope}}\nParameters: {{parameters}}\n\nProduce JSON with controls for device enrollment, compliance policies, and conditional access integration.",
    "outputFormat": "json",
    "temperature": 0.2,
    "validationRules": [
      "MDM enrollment must be enforced when mdmRequired is true",
      "Minimum OS version must appear in complianceCheck parameters"
    ]
  },
  "outputSchema": {
    "schemaRef": "adpa/schemas/generated-artifact.schema.json",
    "artifactKind": "hybrid-specification"
  },
  "iacTargets": {
    "azure": {
      "format": "bicep",
      "translatorModule": "adpa/translators/azure/device-compliance.bicep.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/azure/devices-{{requirementId}}.bicep"
    },
    "aws": {
      "format": "terraform",
      "translatorModule": "adpa/translators/aws/device-compliance.tf.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/aws/devices-{{requirementId}}.tf"
    },
    "gcp": {
      "format": "terraform",
      "translatorModule": "adpa/translators/gcp/device-compliance.tf.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/gcp/devices-{{requirementId}}.tf"
    }
  },
  "complianceTargets": {
    "azurePolicy": {
      "format": "azure-policy",
      "translatorModule": "adpa/translators/azure/device-compliance.policy.js",
      "outputPathPattern": "adpa/tenants/{{tenantId}}/deployed/azure/policies/devices-{{requirementId}}.json"
    }
  },
  "rpasBinding": {
    "csrBaseline": "CSR-42",
    "driftClass": "configuration",
    "tarColArtifactId": "TAR-ADPA-001"
  }
}
