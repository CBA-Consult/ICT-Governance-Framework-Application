{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ict-governance.local/adpa/schemas/compliance-notification-envelope.schema.json",
  "title": "Compliance Notification Envelope",
  "description": "Client-facing non-compliance notification. Must explicitly name which certification controls are non-conformant — never send a whole-standard failure without control-level detail.",
  "type": "object",
  "required": ["notificationClass", "tenantId", "frameworkImpacts"],
  "properties": {
    "notificationClass": {
      "type": "string",
      "const": "compliance-non-conformance"
    },
    "tenantId": { "type": "string" },
    "requirementId": { "type": "string" },
    "validationId": { "type": "string" },
    "assetId": { "type": "string" },
    "lineage": { "type": "object" },
    "frameworkImpacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["certificationId", "framework", "controlId", "complianceStatus", "triggeredBy"],
        "properties": {
          "certificationId": { "type": "string", "description": "e.g. ISO-27001" },
          "certificationLabel": { "type": "string", "description": "e.g. ISO/IEC 27001" },
          "framework": { "type": "string" },
          "controlId": { "type": "string", "description": "e.g. A.9.2.1" },
          "controlName": { "type": "string" },
          "complianceStatus": {
            "type": "string",
            "enum": ["non-conformant", "at-risk", "partially-conformant"]
          },
          "triggeredBy": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "triggerType": { "type": "string" },
                "ruleId": { "type": "string" },
                "controlId": { "type": "string" },
                "expected": { "type": "string" },
                "observed": { "type": "string" },
                "assetId": { "type": "string" },
                "mapsToAcceptanceCriteria": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "mitigationPlan": { "type": "object" },
    "gaps": { "type": "array" },
    "issuedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
