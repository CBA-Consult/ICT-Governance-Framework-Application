          "title": "Login blocked until MFA device registration complete",
          "description": "System enforces Conditional Access so users cannot sign in without MFA registration. At first login the user is prompted to complete MFA device registration before any system access is granted — no bypass except approved break-glass.",
          "accountableParty": "governance-service",
          "responsibilityType": "service",
          "monitorability": { "type": "deterministic", "confidenceLevel": "high" },
          "obligationClass": "automated-control",
