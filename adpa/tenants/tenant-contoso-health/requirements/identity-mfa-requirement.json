{
  "requirementId": "identity-mfa-requirement",
  "tenantId": "tenant-contoso-health",
  "templateId": "identity-access-control",
  "title": "Mandatory MFA for all privileged and standard users",
  "statement": "All users accessing corporate workloads must authenticate with multi-factor authentication. Privileged roles require JIT elevation with time-bound access. Guest access is restricted to approved collaboration scenarios.",
  "rationale": "Aligns with Zero Trust maturity target and NIST CSF PR.AA controls. Reduces credential theft risk identified in Sentinel telemetry.",
  "priority": "critical",
  "status": "approved",
  "pillar": "identity",
  "controlObjective": "Enforce strong authentication and least-privilege access across all cloud subscriptions.",
  "acceptanceCriteria": [
    "100% of active-eligible users enrolled in MFA within 30 days of account creation (user-account-created states excluded from risk denominator)",
    "Users cannot sign in until MFA device registration is complete — registration prompt enforced at login",
    "Privileged roles use JIT elevation with maximum 4-hour sessions",
    "Guest users blocked from administrative roles",
    "Conditional access policies enforce compliant device state"
  ],
  "scope": {
    "subscriptions": ["sub-contoso-prod-001", "sub-contoso-dev-002"],
    "workloads": ["microsoft-365", "azure-platform"],
    "cloudProviders": ["azure"]
  },
  "parameters": {
    "mfaRequired": true,
    "onboardingGracePeriodDays": 30,
    "enrollmentDenominator": "active-eligible-users",
    "excludeAccountStatesFromRisk": ["user-account-created", "pending-onboarding", "inactive-not-yet-eligible"],
    "privilegedAccessModel": "jit",
    "conditionalAccessPolicies": ["require-mfa", "require-compliant-device"],
    "guestAccessAllowed": false,
    "breakGlassEnabled": true
  },
  "frameworkMappings": [
    {
      "framework": "NIST-CSF-2.0",
      "controlId": "PR.AA-01",
      "controlName": "Identities and credentials are managed"
    },
    {
      "framework": "ISO-27001",
      "controlId": "A.9.2.1",
      "controlName": "User registration and de-registration"
    },
    {
      "framework": "ISO-27001",
      "controlId": "A.9.4.2",
      "controlName": "Secure log-on procedures"
    }
  ],
  "deploymentExpectations": {
    "expectedHealthState": "healthy",
    "expectedComplianceState": "Compliant",
    "vendorDeliverableProfile": {
      "summary": "Microsoft Entra ID and Conditional Access must deliver MFA for all users, JIT for privileged roles, guest restrictions, and compliant-device enforcement per approved parameters.",
      "requiredCapabilities": [
        "entra-id-mfa-enrollment-100pct",
        "privileged-identity-management-jit-4h-max",
        "conditional-access-require-mfa",
        "conditional-access-require-compliant-device",
        "conditional-access-block-until-mfa-registered",
        "guest-administrative-role-block"
      ],
      "evidenceTypes": [
        "azure-policy-compliance-state",
        "microsoft-entra-sign-in-logs",
        "pim-activation-audit"
      ]
    },
    "onFailure": {
      "driftType": "security",
      "severity": "CRITICAL",
      "remediationTemplateId": "identity-access-control",
      "emitClientEscalation": true,
      "emitSecOpsIncident": false,
      "blockCsrBaseline": true
    },
    "monitoringRules": [
      {
        "ruleId": "identity-mfa-enrollment",
        "controlId": "identity-mfa-enforcement",
        "mapsToAcceptanceCriteria": 0,
        "checkType": "azure-policy-scan",
        "frequency": "daily",
        "expectedState": "100% of active-eligible users enrolled in MFA within 30 days; user-account-created and pending-onboarding accounts excluded",
        "enrollmentDenominator": "active-eligible-users",
        "onboardingGracePeriodDays": 30,
        "excludeAccountStatesFromRisk": ["user-account-created", "pending-onboarding", "inactive-not-yet-eligible"],
        "frameworkControlRef": "NIST-CSF-2.0 PR.AA-01",
        "severityOnFail": "critical",
        "remediationTemplateId": "identity-access-control",
        "responsibleParty": "governance-service"
      },
      {
        "ruleId": "identity-mfa-login-registration-gate",
        "controlId": "identity-mfa-login-gate",
        "mapsToAcceptanceCriteria": 1,
        "checkType": "azure-policy-scan",
        "frequency": "continuous",
        "expectedState": "Sign-in blocked until MFA device registration complete; user prompted to register at login",
        "frameworkControlRef": "NIST-CSF-2.0 PR.AA-01",
        "severityOnFail": "critical",
        "remediationTemplateId": "identity-access-control",
        "responsibleParty": "governance-service"
      },
      {
        "ruleId": "identity-jit-privileged",
        "controlId": "identity-jit-privileged",
        "mapsToAcceptanceCriteria": 2,
        "checkType": "azure-policy-scan",
        "frequency": "daily",
        "expectedState": "Privileged roles use JIT elevation with maximum 4-hour sessions",
        "frameworkControlRef": "NIST-CSF-2.0 PR.AA-01",
        "severityOnFail": "high",
        "remediationTemplateId": "identity-access-control",
        "responsibleParty": "governance-service"
      },
      {
        "ruleId": "identity-guest-block",
        "controlId": "identity-guest-restriction",
        "mapsToAcceptanceCriteria": 3,
        "checkType": "azure-policy-scan",
        "frequency": "daily",
        "expectedState": "Guest users blocked from administrative roles",
        "frameworkControlRef": "NIST-CSF-2.0 PR.AA-01",
        "severityOnFail": "high",
        "remediationTemplateId": "identity-access-control",
        "responsibleParty": "governance-service"
      },
      {
        "ruleId": "identity-compliant-device",
        "controlId": "identity-device-compliance",
        "mapsToAcceptanceCriteria": 4,
        "checkType": "azure-policy-scan",
        "frequency": "daily",
        "expectedState": "Conditional access policies enforce compliant device state",
        "severityOnFail": "high",
        "remediationTemplateId": "identity-access-control",
        "responsibleParty": "governance-service"
      }
    ],
    "cloudProfiles": {
      "azure": {
        "checkType": "azure-policy-scan",
        "complianceTarget": "azurePolicy",
        "iacFormat": "bicep"
      }
    },
    "timeboundOnboarding": {
      "enabled": true,
      "windowDays": 30,
      "windowStartsAt": "account-created",
      "windowEndsAt": "mfa-registered",
      "accountStatesInWindow": ["user-account-created", "pending-onboarding", "inactive-not-yet-eligible"],
      "accessDuringWindow": "blocked-until-mfa-registered",
      "riskTreatment": "excluded-from-fair-denominator",
      "escalateWhenWindowExpiresWithoutMfa": true,
      "linkedRuleIds": ["identity-mfa-enrollment", "identity-mfa-login-registration-gate"],
      "summary": "30-day timebound onboarding from account creation. Users in user-account-created state are not active, excluded from FAIR/ALE risk, and blocked from sign-in until MFA device registration completes."
    },
    "serviceResponsibilityBoundary": {
      "summary": "The governance service enforces MFA at login — users cannot access systems until device registration is complete. The client maintains new-user onboarding on-premises; account creation and MFA device registration take time, but access remains blocked until registration succeeds.",
      "serviceObligations": [
        {
          "obligationId": "svc-mfa-approval-enforcement",
          "title": "MFA enrollment for active-eligible users only",
          "description": "System monitors MFA enrollment against active-eligible users within the 30-day onboarding window. User-account-created and pending-onboarding accounts are excluded from the risk denominator — they should not be active and cannot sign in until MFA registration completes.",
          "accountableParty": "governance-service",
          "responsibilityType": "service",
          "monitorability": { "type": "deterministic", "confidenceLevel": "high" },
          "obligationClass": "automated-control",
          "linkedRuleIds": ["identity-mfa-enrollment"],
